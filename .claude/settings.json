{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git push origin main)",
      "Bash(git push origin *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(vercel --yes)",
      "Bash(vercel --prod)",
      "Bash(vercel deploy *)",
      "Bash(vercel ls*)",
      "Bash(vercel alias set *)",
      "Bash(vercel alias ls*)",
      "Bash(npx next build*)",
      "Bash(npm run build*)",
      "Bash(npx tsc --noEmit*)"
    ]
  }
}
